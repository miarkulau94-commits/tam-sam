# AutoScaleX Pro 2.2 - Пример конфигурации
# 1. Скопируйте этот файл в .env (в корень репозитория или в "AutoScaleX Pro 2.2/")
# 2. Заполните минимум: ENCRYPTION_SECRET (32+ символов), TG_TOKEN, TG_ADMIN_ID
# Без ENCRYPTION_SECRET бот не запустится в production (BINGX_SANDBOX=false).

# BingX API (опционально, пользователи могут вводить свои ключи через бота)
BINGX_API_KEY=
BINGX_SECRET=

# Telegram (токен от @BotFather, ID администратора)
TG_TOKEN=your_bot_token_from_botfather
TG_ADMIN_ID=0

# Шифрование API ключей (ОБЯЗАТЕЛЬНО! Без этого бот не стартует при BINGX_SANDBOX=false)
ENCRYPTION_SECRET=your_random_secret_min_32_chars

# Торговля
SYMBOL=ETH-USDT
MIN_ORDER=20
BINGX_SANDBOX=false
# Комиссия биржи (0.001 = 0.1%, по умолчанию 0.001)
FEE_RATE=0.001

# Логирование (true — в файл + консоль, false — только в файл, удобно для Docker)
CONSOLE_LOG=true

# Реферальная система
REFERRAL_LINK=https://example.com/invite/your_code/
