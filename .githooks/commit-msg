#!/bin/sh
# Блокирует коммит, если в сообщении всё ещё есть атрибуция Cursor.
# Подключение: из корня репозитория: git config core.hooksPath .githooks

msgfile="$1"
[ -n "$msgfile" ] && [ -f "$msgfile" ] || exit 0

if grep -qF 'Сделано с: Курсор' "$msgfile" 2>/dev/null \
	|| grep -qF 'Сделано с:Курсор' "$msgfile" 2>/dev/null \
	|| grep -qF 'Сделано с : Курсор' "$msgfile" 2>/dev/null \
	|| grep -qiE 'Co-authored-by:.*[Cc]ursor' "$msgfile" 2>/dev/null \
	|| grep -qF 'Generated with Cursor' "$msgfile" 2>/dev/null; then
	echo >&2 "Коммит отклонён: удалите из сообщения строки вроде «Сделано с: Курсор» и аналоги."
	exit 1
fi
exit 0
