# AutoScaleX Pro 2.2 - Пример конфигурации
# Скопируйте в .env и заполните значения
#
# === ОБЯЗАТЕЛЬНО ДЛЯ ЗАПУСКА ===
# config.py загружает ENCRYPTION_SECRET из .env. Если не задан и BINGX_SANDBOX=false — main.py сделает sys.exit(1).
# Перед первым запуском: скопируйте в .env и задайте:
#   1. ENCRYPTION_SECRET — минимум 32 символа (случайная строка)
#   2. TG_TOKEN — токен от @BotFather
#   3. TG_ADMIN_ID — ваш Telegram user ID (для /stop и админ-панели)
# ================================

# BingX API (опционально, пользователи могут вводить свои ключи через бота)
BINGX_API_KEY=
BINGX_SECRET=

# Telegram (токен от @BotFather, ID администратора)
TG_TOKEN=your_bot_token_from_botfather
# Production: задайте TG_ADMIN_ID для /stop и админ-панели
TG_ADMIN_ID=0

# Шифрование API ключей (ОБЯЗАТЕЛЬНО для production!)
ENCRYPTION_SECRET=your_random_secret_min_32_chars

# Торговля
SYMBOL=ETH-USDT
MIN_ORDER=20
BINGX_SANDBOX=false
# Комиссия биржи (0.001 = 0.1%, по умолчанию 0.001)
FEE_RATE=0.001
# MinVolume для ETH/BTC (BingX, по умолчанию 0.0004)
MIN_QTY_FLOOR_ETH_BTC=0.0004

# Логирование (true — в файл + консоль, false — только в файл, удобно для Docker)
CONSOLE_LOG=true
# Троттлинг критических уведомлений в Telegram (секунд на пользователя, по умолчанию 1800 = 30 мин)
ERROR_NOTIFY_COOLDOWN=1800

# Синхронизация с биржей (опционально; см. DEPLOY_VPS.md, ARCHITECTURE_AND_SCENARIOS.md §1.2)
# SYNC_GET_ORDER_MAX_PER_CALL=10
# SYNC_BALANCE_MAX_GET_ORDER=3

# Поиск свободного уровня сетки после исполнения ордера (сколько шагов по grid_step_pct до мелких отступов; см. GRID_FREE_LEVELS.md)
# GRID_FREE_MAX_STEPS=5

# Реферальная система
REFERRAL_LINK=https://example.com/invite/your_code/
